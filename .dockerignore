# ==========================================
# 通用
# ==========================================
.git
**/*.md
LICENSE

# ==========================================
# Node
# ==========================================
**/node_modules
**/dist
**/build
**/coverage
**/.cache
**/.turbo
.vscode
.idea

# ==========================================
# 🚨 大体积目录 (关键！避免拷入镜像)
# ==========================================
data/
backup.sql
certs/
nginx/
redis/
database/
read/

# ==========================================
# 不需要打包的 App — 排除源码，保留 package.json (yarn 工作区解析需要)
# ==========================================
apps/liveness-web/**
!apps/liveness-web/package.json

# ==========================================
# 环境变量 (运行时通过 env_file 注入)
# ==========================================
.env
.env.*
deploy/.env.dev
deploy/.env.prod

# ==========================================
# Docker 文件自身
# ==========================================
Dockerfile*
compose*.yml

# ==========================================
# 日志与临时文件
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db

# ==========================================
# Yarn
# ==========================================
.yarn/unplugged
.yarn/build-state.yml
.pnp.*

# ==========================================
# 安全文件
# ==========================================
*.pem
*.key
*.crt
