NEXT_PUBLIC_APP_ENV=development
# When running locally without Docker, point to local nginx proxy
# https://admin-dev.joyminis.com already proxies /api → backend
NEXT_PUBLIC_API_BASE_URL=/api
# Server Components (SSR) 直连后端绝对地址（不走浏览器 /api 代理）
# Docker 环境由 compose.yml 注入覆盖（http://lucky-backend-dev:3000）
INTERNAL_API_URL=http://localhost:3000
