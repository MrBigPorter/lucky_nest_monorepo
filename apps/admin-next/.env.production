NEXT_PUBLIC_APP_ENV=production
# API base URL is injected at build time via CI secret (NEXT_PUBLIC_API_BASE_URL).
# This file keeps a safe production fallback with /api prefix for local prod builds.
NEXT_PUBLIC_API_BASE_URL=https://api.joyminis.com/api
# Cloudflare R2 public CDN domain
NEXT_PUBLIC_IMG_BASE_URL=https://img.joyminis.com
