# E2E 测试环境变量
# 复制此文件为 .env.test.local 并填入真实值（本地调试用）
# CI 中通过 GitHub Secrets 注入，不需要此文件

# Playwright 测试目标地址
# 本地开发: https://admin-dev.joyminis.com
# CI 中自动设置为 http://localhost:4001
PLAYWRIGHT_BASE_URL=https://admin-dev.joyminis.com

# 管理员账号（用于 E2E 登录流程测试）
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=your-dev-admin-password-here

