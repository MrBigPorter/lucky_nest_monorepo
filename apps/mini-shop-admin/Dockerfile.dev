# ==========================================
# Mini Shop Admin 开发环境 Dockerfile
# ==========================================
# 基于 base 镜像 (已包含 node + yarn + 全部依赖)
# 构建 base: docker build -f Dockerfile.base -t lucky-monorepo-base .

FROM lucky-monorepo-base

WORKDIR /app

# Dev 模式下源码通过 compose volume 挂载 (.:/app)
# 不需要 COPY 源码

EXPOSE 4000

CMD ["yarn", "workspace", "@lucky/mini-shop-admin", "dev"]