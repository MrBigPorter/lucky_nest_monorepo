/// 推送设备表 (用于 FCM)
model Device {
  /// FCM Token 作为主键 (Token 是唯一的且最重要)
  token      String   @id @map("fcm_token") @db.VarChar(255)

  /// 平台类型: android / ios / web
  platform   String   @map("platform") @db.VarChar(20)

  /// 绑定用户ID (可为空! 允许游客存在)
  userId     String?  @map("user_id") @db.VarChar(32)

  /// 最后活跃时间 (用于清洗死粉，比如超过6个月不活跃就不发了)
  lastActive DateTime @default(now()) @map("last_active_at")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  /// 关联用户 (当用户退出登录时，User 变成 null，但记录保留)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platform])
  @@index([lastActive])
  @@map("devices") // 这里的表名叫做 devices，区别于 user_devices
}

// ==========================================
// JOYMINIS IM MODULE (通用聊天模块)
// ==========================================

// 1. 通用会话表
model Conversation {
  id           String   @id @default(cuid()) // IM 内部 ID

  // 类型: "GROUP"(拼团), "DIRECT"(私信), "SUPPORT"(客服)
  type         ConversationType

  //  业务钩子: 存 TreasureGroup.groupId
  businessId   String?  @unique

  // 2. 普通群/私聊专用
  name         String?          // 群名 (私聊可为空)
  avatar       String?          // 群头像
  ownerId      String?          // 群主ID (普通群用)

  // [新增] 会话状态: NORMAL(正常), ARCHIVED(归档/解散), MUTED(全员禁言)
  status       Int              @default(1)

  /// 全员禁言开关: false-关 true-开
  isMuteAll        Boolean   @default(false) @map("is_mute_all")
  /// 加群审批开关: false-关 true-开
  joinNeedApproval Boolean   @default(false) @map("join_need_approval")
  /// 群公告内容 (支持简单的 String 或 JSON 结构)
  announcement     String?   @map("announcement") @db.VarChar(2000)
  announcementAt DateTime?

  // 快照 (用于列表页快速渲染)
  lastMsgContent String?
  lastMsgType    Int?      @default(0)
  lastMsgTime    DateTime?
  lastMsgSeqId   Int       @default(0) //  全局 SeqID 发号器
  // [新增] 快照发送者: 列表页直接显示 "SenderName: Content"
  lastMsgSenderId String?

  // 关联
  messages     ChatMessage[]
  members      ChatMember[]
  joinRequests GroupJoinRequest[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ConversationType {
  GROUP  // 手动创建的群 (兴趣群、闲聊群)
  DIRECT // 私聊 (点对点)
  SUPPORT // 客服聊天 (用户与客服之间)
  BUSINESS // 自动业务群 (拼团、客服、订单) - 也就是之前的 GROUP
}

// 2. 新增：入群申请表
model GroupJoinRequest {
  id        String   @id @default(cuid()) @map("id") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 关系方
  groupId     String   @map("group_id") @db.VarChar(32)
  conversation Conversation @relation(fields: [groupId], references: [id], onDelete: Cascade)

  applicantId String   @map("applicant_id") @db.VarChar(32)
  applicant   User     @relation("UserApplications", fields: [applicantId], references: [id])

  handlerId   String?  @map("handler_id") @db.VarChar(32) // 处理人 (群主/管理员)
  handler     User?    @relation("UserHandledRequests", fields: [handlerId], references: [id])

  // 核心数据
  reason      String?  @db.VarChar(200) // 申请理由
  status      Int      @default(0)      // 0: Pending, 1: Accepted, 2: Rejected

  // 索引优化
  @@index([groupId, status]) // 管理员查“待办”列表时极快
  @@unique([groupId, applicantId, status]) // 【关键】防止重复提交 Pending 状态的申请 (PostgreSQL 支持部分索引更好，但在 Prisma 里这样写有点难，我们在业务层做 Check)
  // 替代方案：不加 Unique，在 Service 层做逻辑判断

  @@map("group_join_requests")
}

// 2. 消息表
model ChatMessage {
  id             String   @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  senderId       String?  // Null = 系统消息
  sender         User?    @relation(fields: [senderId], references: [id])

  type           Int      @default(0) // 0:Text, 1:Image, 2:Audio, 3:Video, 99:System
  content        String   // 文本或 URL
  meta           Json?    // {w, h, duration, size,blurHash }

  //  核心机制
  seqId          Int      // 序列号
  clientTempId   String?  // 前端生成的 UUID (用于去重/ACK)

  isRecalled     Boolean  @default(false)
  createdAt      DateTime @default(now())

  // 这里的 [] 已经是“可选”含义，代表一个消息可以有 0 个或多个隐藏记录
  hiddenByUsers  ChatMessageHide[]

  @@index([conversationId, seqId]) // 关键索引：拉取历史记录
}

model ChatMessageHide {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  @@unique([userId, messageId])
  @@index([userId])

  // 这里的 message 保持必选是安全的，因为隐藏记录产生时，消息一定已经存在
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// 3. 成员表
model ChatMember {
  id             String       @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  // 角色权限
  role           String       @default("MEMBER") // OWNER, ADMIN, MEMBER
  /// 禁言截止时间 (WebRTC/Chat 逻辑判断: now() < mutedUntil ? 禁言 : 正常)
  mutedUntil     DateTime?    @map("muted_until")
  /// 邀请人ID (溯源用，是谁把你拉进群的)
  inviterId      String?      @map("inviter_id")

  // 个性化设置
  nickname       String?      // 在群里的昵称
  //  [建议] 增加置顶功能 (微信的置顶聊天)
  isPinned       Boolean      @default(false)
  isMuted        Boolean      @default(false)

  // 阅读进度 (未读数 = Conversation.lastMsgSeqId - ChatMember.lastReadSeqId)
  lastReadSeqId  Int          @default(0)
  clearedSeqId   Int          @default(0) @map("cleared_seq_id")

  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId]) // 每个人在每个群只能有一条记录
  @@index([conversationId, role]) //  新增索引：快速查找群里的管理员
}

// 补齐好友关系表
model Friend {
  id        String   @id @default(cuid()) @map("id") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id") @db.VarChar(32)
  user      User     @relation("UserFriends", fields: [userId], references: [id])

  friendId  String   @map("friend_id") @db.VarChar(32)
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id])

  remark    String?  @db.VarChar(100) // 备注名
  status    Int      @default(1)      // 1:已添加, 2:黑名单

  @@unique([userId, friendId]) // 关键：防止重复加好友
  @@index([userId])
  @@map("friends")
}

// 新增：只用来存“申请记录” (临时表)
model FriendRequest {
  id        String   @id @default(cuid()) @map("request_id") @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fromUserId String   @map("from_user_id") @db.VarChar(32) // 申请人
  toUserId   String   @map("to_user_id") @db.VarChar(32)   // 被申请人

  reason     String?  @db.VarChar(200) // 验证消息 "我是老王"

  // 状态: 0=待处理, 1=已同意, 2=已拒绝
  status     Int      @default(0) @db.SmallInt

  fromUser   User     @relation("RequestSent", fields: [fromUserId], references: [id])
  toUser     User     @relation("RequestReceived", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId]) // 防止重复申请
  @@index([toUserId, status])      // 方便查"谁加了我"
  @@map("friend_requests")
}

// ==========================================
// 开奖模块（Lottery — 商品归属开奖）
// ==========================================

/// 开奖结果记录（每团一条，记录商品赢家）
model LotteryResult {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now()) @map("created_at")
  groupId       String        @map("group_id") @db.VarChar(32)
  treasureId    String        @map("treasure_id") @db.VarChar(32)
  winnerId      String        @map("winner_id") @db.VarChar(32)
  /// 中奖订单ID（注意：字段名 winnerOrderId，不是 winnerOrder）
  winnerOrderId String        @map("winner_order_id") @db.VarChar(32)
  group         TreasureGroup @relation(fields: [groupId], references: [groupId])
  user          User          @relation(fields: [winnerId], references: [id])

  @@unique([groupId], map: "uk_lottery_group") // 一个团只能开奖一次
  @@index([winnerId])
  @@map("lottery_results")
}

// ==========================================
// 福利抽奖模块（LuckyDraw — 下单后免费抽奖）
// ==========================================

/// 抽奖活动配置（admin 创建）
model LuckyDrawActivity {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  title       String            @db.VarChar(100)
  description String?           @db.VarChar(500)
  /// 绑定商品（null = 全平台任意订单触发）
  treasureId  String?           @map("treasure_id") @db.VarChar(32)
  /// 0=禁用 1=启用
  status      Int               @default(1) @db.SmallInt
  startAt     DateTime?         @map("start_at")
  endAt       DateTime?         @map("end_at")
  treasure    Treasure?         @relation(fields: [treasureId], references: [treasureId])
  prizes      LuckyDrawPrize[]
  tickets     LuckyDrawTicket[]

  @@index([status, startAt, endAt])
  @@map("lucky_draw_activities")
}

/// 奖品配置
model LuckyDrawPrize {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now()) @map("created_at")
  activityId  String            @map("activity_id")
  /// 1=优惠券 2=金币 3=余额 4=谢谢参与
  prizeType   Int               @map("prize_type") @db.SmallInt
  prizeName   String            @map("prize_name") @db.VarChar(100)
  /// 关联优惠券模板（type=1 时必填）
  couponId    String?           @map("coupon_id") @db.VarChar(32)
  /// 奖励数量/金额（type=2/3 时必填）
  prizeValue  Decimal?          @map("prize_value") @db.Decimal(10, 2)
  /// 权重 0-100，同一活动所有奖品之和必须 = 100
  probability Decimal           @db.Decimal(5, 2)
  /// 剩余库存（-1 = 不限）
  stock       Int               @default(-1)
  sortOrder   Int               @default(0) @map("sort_order")
  activity    LuckyDrawActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  coupon      Coupon?           @relation(fields: [couponId], references: [id])
  results     LuckyDrawResult[]

  @@index([activityId])
  @@map("lucky_draw_prizes")
}

/// 用户抽奖券（下单成功时自动发放）
model LuckyDrawTicket {
  id         String            @id @default(cuid())
  createdAt  DateTime          @default(now()) @map("created_at")
  userId     String            @map("user_id") @db.VarChar(32)
  activityId String            @map("activity_id")
  /// 来源订单（幂等键：一个订单对同一活动只能有一张券）
  orderId    String            @map("order_id") @db.VarChar(32)
  used       Boolean           @default(false)
  usedAt     DateTime?         @map("used_at")
  expireAt   DateTime?         @map("expire_at")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity   LuckyDrawActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  result     LuckyDrawResult?

  @@unique([orderId, activityId], map: "uk_ticket_order_activity")
  @@index([userId, used])
  @@map("lucky_draw_tickets")
}

/// 抽奖结果记录
model LuckyDrawResult {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now()) @map("created_at")
  /// 1:1 ticket，保证一张券只对应一次结果
  ticketId      String          @unique @map("ticket_id")
  userId        String          @map("user_id") @db.VarChar(32)
  prizeId       String          @map("prize_id")
  /// 抽奖时的奖品快照（防止奖品被修改后对账出错）
  prizeSnapshot Json            @map("prize_snapshot")
  ticket        LuckyDrawTicket @relation(fields: [ticketId], references: [id])
  prize         LuckyDrawPrize  @relation(fields: [prizeId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prizeId])
  @@map("lucky_draw_results")
}
