  /// 成员类型: 0-真实用户 1-机器人
  memberType  Int           @default(0) @map("member_type") @db.SmallInt
  group       TreasureGroup @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], map: "uk_group_user")
  @@index([groupId], map: "idx_group")
  @@index([userId], map: "idx_user")
  @@index([orderId], map: "idx_order")
  @@map("treasure_group_members")
}

/// banner
model Banner {
  id              String    @id @default(cuid()) @map("banner_id") @db.VarChar(32)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  title           String?   @db.VarChar(200)
  bannerImgUrl    String?   @map("banner_img_url") @db.VarChar(255)
  videoUrl        String?   @map("video_url") @db.VarChar(255)
