  groupId     String        @map("group_id") @db.VarChar(32)
  userId      String        @map("user_id") @db.VarChar(32)
  orderId     String?       @map("order_id") @db.VarChar(32)
  /// 是否团长: 0-否 1-是
  isOwner     Int           @default(0) @map("is_owner") @db.SmallInt
  /// 分享获得金额
