  fileType        Int       @default(1) @map("file_type") @db.SmallInt
  /// 1=首页 2=活动页 3=产品页
  bannerCate      Int       @map("banner_cate") @db.SmallInt
  /// 0=顶部 1=中部 2=底部
  position        Int       @default(0) @map("position") @db.SmallInt
  sortType        Int       @default(1) @map("sort_type") @db.SmallInt
  sortOrder       Int       @default(0) @map("sort_order")
  /// 1=无 2=APP内页 3=产品详情 5=外链
