// 钱包快照
model UserWallet {
  id                 String   @id @default(cuid())
  userId             String   @unique
  realBalance        Decimal  @default(0)     @map("real_balance")         // 现金
  coinBalance        Decimal  @default(0)     @map("coin_balance")         // 金币（先用 Decimal，之后可切 Int）
  frozenBalance      Decimal  @default(0)     @map("frozen_balance")       // 冻结（先留着）
  totalRecharge      Decimal  @default(0)     @map("total_recharge")
  totalWithdraw      Decimal  @default(0)     @map("total_withdraw")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt      @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("user_wallets")
  @@index([userId], map: "idx_user_id")
}

/// 用户收货地址
model UserAddress {
  addressId   String   @id @default(cuid()) @map("address_id") @db.VarChar(32)
  userId      String   @map("user_id") @db.VarChar(32)

  firstName   String?   @map("first_name") @db.VarChar(50)
  lastName    String?   @map("last_name") @db.VarChar(50)
  contactName String   @map("contact_name") @db.VarChar(100)
  phone       String   @db.VarChar(20)

  province    String   @db.VarChar(50)
  city        String   @db.VarChar(50)
  barangay    String   @db.VarChar(50)

  fullAddress String   @map("full_address") @db.Text
  postalCode  String?  @map("postal_code") @db.VarChar(10)

  // 1. 存储 ID (用于外键关联、逻辑计算)
  provinceId  Int      @map("province_id")
  cityId      Int      @map("city_id")
  barangayId  Int      @map("barangay_id")

  // 地址标签 (Home, Office, Other)
  label       String?  @db.VarChar(20)

  isDefault   Int      @default(0) @map("is_default") @db.SmallInt

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 建立地理位置关联
  provinceRel Province @relation(fields: [provinceId], references: [provinceId])
  cityRel     City     @relation(fields: [cityId], references: [cityId])
  barangayRel Barangay @relation(fields: [barangayId], references: [barangayId])

  // deliveries  Delivery[]

  @@index([userId])
  @@index([provinceId])
  @@index([cityId])
  @@map("user_addresses")
}

// 钱包流水
model WalletTransaction {
  id              String   @id @default(cuid()) @map("id") @db.VarChar(32)
  transactionId   String?   @map("transaction_id_ext") @db.VarChar(32)
  transactionNo   String   @unique @map("transaction_no")  @db.VarChar(50)
  userId          String   @map("user_id") @db.VarChar(32)
  walletId        String   @map("wallet_id") @db.VarChar(32)

  beforeBalance  Decimal  @map("before_balance") @db.Decimal(10, 2)
  afterBalance   Decimal  @map("after_balance")  @db.Decimal(10, 2)

  // 1=充值 2=消费 3=退款 4=奖励 5=提现 6=金币兑换 7=邀请奖励
  transactionType Int      @map("transaction_type")  @db.SmallInt
  // 1=现金 2=金币
  balanceType     Int      @map("balance_type")  @db.SmallInt
  amount          Decimal  @map("amount") @db.Decimal(10, 2)
  relatedId       String?  @map("related_id") @db.VarChar(64)
  relatedType     String?  @map("related_type")  @db.VarChar(50)
  description     String?  @map("description")   @db.Text
  remark          String?  @map("remark")        @db.VarChar(500)
  status          Int      @default(1) @map("status")  @db.SmallInt
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet UserWallet? @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
  @@index([userId], map: "idx_user_id_txn")
  @@index([transactionNo], map: "idx_transaction_no")
  @@index([transactionType], map: "idx_type")
  @@index([balanceType], map: "idx_balance_type")
  @@index([createdAt], map: "idx_created_at")
  @@index([userId, transactionType], map: "idx_user_type")
}


// order table
model Order {
  orderId      String   @id @default(cuid()) @map("order_id") @db.VarChar(32)
  orderNo     String   @unique @map("order_no") @db.VarChar(50)
  userId      String   @map("user_id") @db.VarChar(32)
  treasureId  String   @map("treasure_id") @db.VarChar(32)

  originalAmount Decimal  @map("original_amount") @db.Decimal(10, 2)
  discountAmount Decimal  @map("discount_amount") @db.Decimal(10, 2)
  couponAmount   Decimal  @map("coupon_amount") @db.Decimal(10, 2)
  coinAmount    Decimal  @map("coin_amount") @db.Decimal(10, 2)
  finalAmount   Decimal  @map("final_amount") @db.Decimal(10, 2)

  buyQuantity  Int      @map("buy_quantity")
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)

  /// // 1待支付 2已支付 3取消 4退款
  orderStatus Int      @default(1) @map("order_status") @db.SmallInt
  payStatus   Int      @default(0) @map("pay_status") @db.SmallInt
  refundStatus Int      @default(0) @map("refund_status") @db.SmallInt
  /// 退款原因
  refundReason String?  @map("refund_reason") @db.VarChar(255)
  /// 实际退款金额 (记录财务流水)
  refundAmount Decimal? @map("refund_amount") @db.Decimal(10, 2)
  /// 退款时间
  refundedAt   DateTime? @map("refunded_at")
  // 记录操作人
  refundAppliedBy  String?  @map("refund_applied_by") // 申请人ID
  refundAuditedBy  String?  @map("refund_audited_by") // 审核人ID
  refundRejectReason String? @map("refund_reject_reason") // 拒绝原因

  //：支付方式 (1=余额, 2=Xendit)
  // 加了问号 ? 表示可选，旧数据的这个字段会自动变成 null
  paymentMethod Int?     @map("payment_method") @db.SmallInt

  // 第三方流水号 (退款用)
  transactionId String?  @map("transaction_id") @db.VarChar(100)

  groupId     String?  @map("group_id") @db.VarChar(32)
  isGroupOwner Int      @default(0) @map("is_group_owner") @db.SmallInt

  userCouponId String? @unique  @map("user_coupon_id") @db.VarChar(32)
  coinUsed    Decimal  @default(0) @map("coin_used") @db.Decimal(10, 2)

  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // ---  物流状态  ---
  /// 0-待发货 1-已发货 2-已签收
  shippingStatus   Int      @default(0) @map("shipping_status") @db.SmallInt

  // ---  收货地址快照
  shippingAddress  Json?    @map("shipping_address")

  // ---  快递单号  ---
  logisticsCo      String?  @map("logistics_co") @db.VarChar(50)
  trackingNo       String?  @map("tracking_no") @db.VarChar(50)

  // ---  退款与奖励  ---
  hasBonus         Int      @default(0) @map("has_bonus") @db.SmallInt

  user       User    @relation(fields: [userId],references: [id], onDelete: Cascade)
  treasure   Treasure @relation(fields: [treasureId],references: [treasureId], onDelete: Restrict)
  group      TreasureGroup? @relation(fields: [groupId], references: [groupId], onDelete: Cascade)

  userCoupon UserCoupon?    @relation(fields: [userCouponId], references: [id])

  @@index([userId], map: "idx_user_id_order")
  @@index([treasureId], map: "idx_treasure_id_order")
  @@index([orderStatus,payStatus], map: "idx_order_status")
  @@index([groupId], map: "idx_group_id_order")
  @@map("orders")
}

model SystemConfig {
  key       String   @id @map("config_key") @db.VarChar(100)
  value     String   @map("config_value") @db.VarChar(255)

  @@map("system_configs")
}

// ========= Marketing: Coupon System =========

/// 优惠券模板表 (印钞模板)
model Coupon {
  id              String   @id @default(cuid()) @map("coupon_id") @db.VarChar(32)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  /// 优惠券名称
  couponName      String   @map("coupon_name") @db.VarChar(200)
  /// 优惠券代码 (兑换码用)
  couponCode      String?  @unique @map("coupon_code") @db.VarChar(50)

  /// 类型: 1-满减券 2-折扣券 3-无门槛现金券
  couponType      Int      @map("coupon_type") @db.SmallInt
  /// 折扣类型: 1-固定金额(减10块) 2-百分比(打9折)
  discountType    Int      @default(1) @map("discount_type") @db.SmallInt

  /// 面额/折扣值 (如 10.00 或 0.90)
  discountValue   Decimal  @map("discount_value") @db.Decimal(10, 2)
  /// 最低消费门槛 (0代表无门槛)
  minPurchase     Decimal  @default(0) @map("min_purchase_amount") @db.Decimal(10, 2)
  /// 最高抵扣金额 (防止9折券买游艇亏死)
  maxDiscount     Decimal? @map("max_discount_amount") @db.Decimal(10, 2)

  /// 发放类型: 1-系统发放 2-用户领取 3-兑换码 4-邀请奖励
  issueType       Int      @default(2) @map("issue_type") @db.SmallInt

  /// 发行总量 (-1代表不限量)
  totalQuantity   Int      @default(-1) @map("total_quantity")
  /// 已发放数量
  issuedQuantity  Int      @default(0) @map("issued_quantity")
  /// 每人限领 (-1代表不限)
  perUserLimit    Int      @default(1) @map("per_user_limit")

  /// 有效期类型: 1-固定日期范围 2-领券后N天有效
  validType       Int      @default(1) @map("valid_type") @db.SmallInt
  validDays       Int?     @map("valid_days") // 领券后几天
  validStartAt    DateTime? @map("valid_start_time")
  validEndAt      DateTime? @map("valid_end_time")

  /// 状态: 0-禁用/结束 1-进行中
  status          Int      @default(1) @map("status") @db.SmallInt

  description     String?  @map("description") @db.VarChar(500)

  subTitle        String?  @map("sub_title") @db.VarChar(200)
  ruleDesc        String?  @map("rule_desc") @db.Text
  // 关系
  userCoupons     UserCoupon[]

  @@index([status])
  @@index([issueType])
  @@index([validStartAt, validEndAt])
  @@map("coupons")
}

/// 用户优惠券实例表 (用户手里的券)
model UserCoupon {
  id              String   @id @default(cuid()) @map("user_coupon_id") @db.VarChar(32)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  userId          String   @map("user_id") @db.VarChar(32)
  couponId        String   @map("coupon_id") @db.VarChar(32)

  /// 领取方式: 1-系统 2-主动 3-兑换 4-邀请
  receiveType     Int      @default(2) @map("receive_type") @db.SmallInt

  /// 使用状态: 0-未使用 1-已使用 2-已过期 3-作废
  status          Int      @default(0) @map("use_status") @db.SmallInt

  /// 实际抵扣金额
  discountAmount  Decimal? @map("discount_amount") @db.Decimal(10, 2)

  /// 使用时间
  usedAt          DateTime? @map("used_at")


  /// 有效期 (领取时计算固化下来，方便查询)
  validStartAt    DateTime  @map("valid_start_time")
  validEndAt      DateTime  @map("valid_end_time")

  // 关系
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order?

  @@index([userId, status]) // 查"我的可用优惠券"最常用
  @@index([validEndAt])     // 查过期券
  @@map("user_coupons")
}
// ========= Finance: Recharge & Withdraw (Missing Tables) =========

/// 21. 充值订单表
model RechargeOrder {
  rechargeId     String   @id @default(cuid()) @map("recharge_id") @db.VarChar(32)
  rechargeNo     String   @unique @map("recharge_no") @db.VarChar(50)
  userId         String   @map("user_id") @db.VarChar(32)

  // 金额
  rechargeAmount Decimal  @map("recharge_amount") @db.Decimal(10, 2)
  bonusAmount    Decimal  @default(0.00) @map("bonus_amount") @db.Decimal(10, 2)
  actualAmount   Decimal  @map("actual_amount") @db.Decimal(10, 2)

  // 支付
  paymentMethod  Int      @map("payment_method") @db.SmallInt // 1-GCash 2-PayMaya...
  paymentChannel String?  @map("payment_channel") @db.VarChar(50)
  paymentId      String?  @map("payment_id") @db.VarChar(32)

  // 状态: 1-待支付 2-支付中 3-充值成功 4-充值失败 5-已取消
  rechargeStatus Int      @default(1) @map("recharge_status") @db.SmallInt

  // 营销
  activityId     String?  @map("activity_id") @db.VarChar(32)
  firstRecharge  Int      @default(0) @map("first_recharge") @db.SmallInt

  // 数据
  thirdPartyOrderNo String? @map("third_party_order_no") @db.VarChar(100)
  callbackData      Json?   @map("callback_data")

  paidAt        DateTime? @map("paid_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rechargeNo])
  @@index([rechargeStatus])
  @@map("recharge_orders")
}

/// 22. 提现订单表
model WithdrawOrder {
  withdrawId     String   @id @default(cuid()) @map("withdraw_id") @db.VarChar(32)
  withdrawNo     String   @unique @map("withdraw_no") @db.VarChar(50)
  userId         String   @map("user_id") @db.VarChar(32)

  // 金额
  withdrawAmount Decimal  @map("withdraw_amount") @db.Decimal(10, 2)
  feeAmount      Decimal  @default(0.00) @map("fee_amount") @db.Decimal(10, 2)
  actualAmount   Decimal  @map("actual_amount") @db.Decimal(10, 2)

  // 方式
  withdrawMethod Int      @map("withdraw_method") @db.SmallInt
  withdrawAccount String  @map("withdraw_account") @db.VarChar(100)
  accountName     String? @map("account_name") @db.VarChar(100)
  bankName        String? @map("bank_name") @db.VarChar(100)

  // 状态: 1-待审核 2-审核通过 3-处理中 4-提现成功 5-审核拒绝 6-提现失败
  withdrawStatus  Int     @default(1) @map("withdraw_status") @db.SmallInt

  auditResult     String? @map("audit_result") @db.VarChar(500)
  rejectReason    String? @map("reject_reason") @db.VarChar(500)
  auditorId       String? @map("auditor_id") @db.VarChar(32)

  thirdPartyOrderNo String? @map("third_party_order_no") @db.VarChar(100)
  transferVoucher   String? @map("transfer_voucher") @db.VarChar(255)

  appliedAt   DateTime  @default(now()) @map("applied_at") // 设置默认值方便
  auditedAt   DateTime? @map("audited_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([withdrawNo])
  @@index([withdrawStatus])
  @@map("withdraw_orders")
}



/// 省份配置 (Philippines Provinces)
model Province {
  provinceId   Int      @id @default(autoincrement()) @map("province_id")
  provinceName String   @unique @map("province_name") @db.VarChar(100)
  provinceCode String?  @map("province_code") @db.VarChar(50)
  sortOrder    Int      @default(0) @map("sort_order")
  status       Int      @default(1) @db.SmallInt // 1=启用

  cities       City[]
  userAddresses UserAddress[]

  @@map("provinces")
}

/// 城市配置 (Philippines Cities)
model City {
  cityId     Int      @id @default(autoincrement()) @map("city_id")
  provinceId Int      @map("province_id")
  cityName   String   @map("city_name") @db.VarChar(100)
  cityCode   String?  @map("city_code") @db.VarChar(50)
  postalCode String?  @map("postal_code") @db.VarChar(10)
  status     Int      @default(1) @db.SmallInt // 1=启用

  province   Province @relation(fields: [provinceId], references: [provinceId])
  barangays  Barangay[] // 关联下级社区
  userAddresses UserAddress[]

  @@index([provinceId])
  @@map("cities")
}

/// 菲律宾最小行政单位 Barangay (物流必填)
model Barangay {
  barangayId   Int      @id @default(autoincrement()) @map("barangay_id")
  cityId       Int      @map("city_id")
  barangayName String   @map("barangay_name") @db.VarChar(100)
  status       Int      @default(1) @db.SmallInt

  city         City     @relation(fields: [cityId], references: [cityId])
  userAddresses UserAddress[]

  @@unique([cityId, barangayName])

  @@index([cityId])
  @@map("barangays")
}

// 证件类型配置表
model KycIdType {
  // 这里直接用枚举的 Int 值作为主键，方便对应
  id          Int      @id @map("id")

  // 内部代号: "PH_DRIVER_LICENSE" (给开发者看)
  code        String   @unique @db.VarChar(50)

  // 展示名称: "Driver's License" (给用户看，支持随时改)
  label       String   @db.VarChar(100)

  // 国家代码: "PH", "CN", "GLOBAL" (用于前端筛选)
  country     String   @default("GLOBAL") @db.VarChar(10)

  // 排序权重 (数字越小越靠前)
  sortOrder   Int      @default(0) @map("sort_order")

  // 状态: 1-启用 0-禁用 (比如某个证件接口挂了，可以临时下架)
  status      Int      @default(1) @db.SmallInt

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("kyc_id_types")
}

/// KYC 职业类型配置 (Occupations)
model KycOccupationType {
  occupationId   Int      @id @default(autoincrement()) @map("occupation_id")
  occupationName String   @map("occupation_name") @db.VarChar(200)
  category       String?  @map("occupation_category") @db.VarChar(50)

  sortOrder      Int      @default(0) @map("sort_order")
  status         Int      @default(1) @db.SmallInt

  createdAt      DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("kyc_occupation_types")
}


/// KYC 认证记录
model KycRecord {
  id            String   @id @default(cuid()) @map("id") @db.VarChar(32)
  userId        String   @map("user_id") @db.VarChar(32)
  sessionId     String?  @unique @map("session_id")

  // 状态: 0-未提交 1-审核中 2-审核失败 3-待补充 4-已通过 5-系统拒绝(自动风控)
  kycStatus     Int      @default(0) @map("kyc_status") @db.SmallInt

  // === 1. 证件核心信息 ===
  idType        Int      @default(1) @map("id_type")
  idNumber      String?  @map("id_number") @db.VarChar(50)
  firstName     String?  @map("first_name") @db.VarChar(50)
  middleName    String?  @map("middle_name") @db.VarChar(50)
  lastName      String?  @map("last_name") @db.VarChar(50)
  realName      String?  @map("real_name") @db.VarChar(150)

  gender        String?  @db.VarChar(10)
  birthday      DateTime? @map("birthday")

  // [新增] 出生地 (AMLA 合规必填)
  placeOfBirth  String?   @map("place_of_birth") @db.VarChar(100)
  // [新增] 国籍 (区分外国人)
  nationality   String?   @map("nationality") @db.VarChar(50)

  expiryDate    DateTime? @map("expiry_date")
  // [新增] 签发日期 (辅助验证证件真伪)
  issueDate     DateTime? @map("issue_date")

  countryCode   Int?      @map("country_code")

  // === 2. 财务能力 ===
  sourceOfIncome String? @map("source_of_income")
  natureOfWork   String? @map("nature_of_work")
  // [新增] 公司名称/雇主 (风控核查用)
  employerName   String? @map("employer_name") @db.VarChar(100)

  // === 3. 详细地址信息 (Philippines Standard) ===
  province      String?  @db.VarChar(100)
  city          String?  @db.VarChar(100)
  barangay      String?  @db.VarChar(100)
  postalCode    String?  @map("postal_code") @db.VarChar(20)
  address       String?  @db.Text

  // 当前居住地
  isSameAddress Boolean  @default(true) @map("is_same_address")
  currentAddress Json?   @map("current_address_json")

  // === 4. 图片凭证 ===
  idCardFront   String?  @map("id_card_front") @db.VarChar(255)
  idCardBack    String?  @map("id_card_back") @db.VarChar(255)
  selfiePhoto   String?  @map("selfie_photo") @db.VarChar(255)
  assetProof    String?  @map("asset_proof") @db.VarChar(255)
  optionalPhoto String?  @map("optional_photo") @db.VarChar(255)

  // === 5. 活体与风控数据 ===
  faceImage     String?  @map("face_image") @db.VarChar(255)
  livenessScore Float?   @map("liveness_score")
  securityFlags Json?    @map("security_flags")

  // [新增] OCR 原始数据备份 (用于对比用户是否篡改了表单)
  ocrRawData    Json?    @map("ocr_raw_data")

  // [新增] 自动计算的风险等级 (0-Safe, 1-Review, 2-High Risk)
  riskLevel     Int      @default(0) @map("risk_level") @db.SmallInt

  // === 6. 设备指纹 ===
  ipAddress     String?  @map("ip_address") @db.VarChar(50)
  deviceId      String?  @map("device_id") @db.VarChar(100)
  deviceModel   String?  @map("device_model") @db.VarChar(100)
  // [新增] App 版本号 (用于排查旧版本兼容性问题)
  appVersion    String?  @map("app_version") @db.VarChar(20)

  // === 7. 审核结果 ===
  auditResult   String?  @map("audit_result") @db.Text
  rejectReason  String?  @map("reject_reason") @db.VarChar(255)
  auditorId     String?  @map("auditor_id") @db.VarChar(32)

  submittedAt   DateTime? @map("submitted_at")
  auditedAt     DateTime? @map("audited_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // 复合索引：同时查证件号 + 国家 + 证件类型
  // 场景：查找“菲律宾(63)的护照(Type 1)号码为 A1234567”的记录
  @@index([countryCode, idType, idNumber])
  @@map("kyc_records")
}


model KycLivenessAttempt {
  id        String   @id @default(cuid()) @db.VarChar(32)
  userId    String   @unique @map("user_id") @db.VarChar(32)

  attemptId String   @map("attempt_id") @db.VarChar(64)  // 第三方活体检测服务的尝试ID
  token     String   @map("token") @db.VarChar(128) // 第三方活体检测服务的访问令牌
  sessionId String?  @map("session_id") @db.VarChar(64) // 关联的KYC会话ID

  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("kyc_liveness_attempts")
}

model KycLivenessSession {
  id         String   @id @default(cuid()) @db.VarChar(32)
  userId     String   @db.VarChar(32)
  sessionId  String   @unique @map("session_id")
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@map("kyc_liveness_sessions")
}

/// 秒杀/抢购场次表
model FlashSaleSession {
  id        String   @id @default(cuid())
  title     String   @map("title") @db.VarChar(50) // 例如 "10:00 AM Rush"

  startTime DateTime @map("start_time") // 2025-12-30 10:00:00
  endTime   DateTime @map("end_time")   // 2025-12-30 12:00:00

  status    Int      @default(1) // 1=启用

  products  FlashSaleProduct[]

  @@map("flash_sale_sessions")
  @@index([startTime, endTime])
}

/// 秒杀商品关联
model FlashSaleProduct {
  id        String @id @default(cuid())
  sessionId String @map("session_id")
  treasureId String @map("treasure_id")
  // 秒杀库存 (独立于总库存，防止秒杀把正价库存卖空)
  flashStock Int    @default(0) @map("flash_stock")
  // 秒杀价格
  flashPrice Decimal @map("flash_price") @db.Decimal(10, 2)

  sortOrder Int    @default(0)

  session   FlashSaleSession @relation(fields: [sessionId], references: [id])
  treasure  Treasure         @relation(fields: [treasureId], references: [treasureId])

  @@map("flash_sale_products")
}