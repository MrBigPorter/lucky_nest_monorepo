/// 支付渠道配置表 (控制收银台显示)
model PaymentChannel {
  id           Int      @id @default(autoincrement())
  /// 渠道编码: "PH_GCASH", "PH_PAYMAYA", "PH_BDO" (对应 Xendit)
  code         String   @unique @db.VarChar(50)
  /// 显示名称: "GCash", "PayMaya"
  name         String   @db.VarChar(100)
  /// 图标 URL
  icon         String?  @db.VarChar(255)
  /// 渠道类型: 1-充值(Money In) 2-提现(Money Out)
  type         Int      @default(1) @db.SmallInt
  /// 货币单位
  currency     String   @default("PHP") @db.VarChar(10)
  /// 最小金额限制
  minAmount    Decimal  @default(0) @map("min_amount") @db.Decimal(10, 2)
  /// 最大金额限制
  maxAmount    Decimal  @default(50000) @map("max_amount") @db.Decimal(10, 2)
  /// 固定金额选项 (JSON数组)
  /// 存: [100, 200, 500, 1000] 或者带 Bonus: [{"val":100, "bonus":"+2%"}]
  fixedAmounts Json?    @map("fixed_amounts")
  /// 是否允许自定义输入金额
  isCustom     Boolean  @default(true) @map("is_custom")
  /// 费率 (百分比，例如 0.02 代表 2%) - 用于后台计算成本
  feeRate      Decimal  @default(0) @map("fee_rate") @db.Decimal(5, 4)
  /// 固定手续费 (例如每笔 10 PHP)
  feeFixed     Decimal  @default(0) @map("fee_fixed") @db.Decimal(10, 2)
  /// 排序 (越小越靠前)
  sortOrder    Int      @default(0) @map("sort_order")
  /// 状态: 1-启用 0-禁用 2-维护中
  status       Int      @default(1) @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([type, status])
  @@map("payment_channels")
}

/// 22. 提现订单表
model WithdrawOrder {
  withdrawId        String    @id @default(cuid()) @map("withdraw_id") @db.VarChar(32)
  withdrawNo        String    @unique @map("withdraw_no") @db.VarChar(50)
  userId            String    @map("user_id") @db.VarChar(32)
  withdrawAmount    Decimal   @map("withdraw_amount") @db.Decimal(10, 2)
  feeAmount         Decimal   @default(0.00) @map("fee_amount") @db.Decimal(10, 2)
  actualAmount      Decimal   @map("actual_amount") @db.Decimal(10, 2)
  withdrawMethod    Int       @map("withdraw_method") @db.SmallInt
  withdrawAccount   String    @map("withdraw_account") @db.VarChar(100)
  accountName       String?   @map("account_name") @db.VarChar(100)
  bankName          String?   @map("bank_name") @db.VarChar(100)
  withdrawStatus    Int       @default(1) @map("withdraw_status") @db.SmallInt
  auditResult       String?   @map("audit_result") @db.VarChar(500)
  rejectReason      String?   @map("reject_reason") @db.VarChar(500)
  auditorId         String?   @map("auditor_id") @db.VarChar(32)
  thirdPartyOrderNo String?   @map("third_party_order_no") @db.VarChar(100)
  transferVoucher   String?   @map("transfer_voucher") @db.VarChar(255)
  appliedAt         DateTime  @default(now()) @map("applied_at")
  auditedAt         DateTime? @map("audited_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  channelCode       String?   @map("channel_code") @db.VarChar(50)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([withdrawNo])
  @@index([withdrawStatus])
  @@map("withdraw_orders")
}

/// 省份配置 (Philippines Provinces)
model Province {
  provinceId    Int           @id @default(autoincrement()) @map("province_id")
  provinceName  String        @unique @map("province_name") @db.VarChar(100)
  provinceCode  String?       @map("province_code") @db.VarChar(50)
  sortOrder     Int           @default(0) @map("sort_order")
  status        Int           @default(1) @db.SmallInt
  cities        City[]
  userAddresses UserAddress[]

  @@map("provinces")
}

/// 城市配置 (Philippines Cities)
model City {
  cityId        Int           @id @default(autoincrement()) @map("city_id")
  provinceId    Int           @map("province_id")
  cityName      String        @map("city_name") @db.VarChar(100)
