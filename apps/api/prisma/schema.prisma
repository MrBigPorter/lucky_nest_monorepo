model Order {
  orderId            String         @id @default(cuid()) @map("order_id") @db.VarChar(32)
  orderNo            String         @unique @map("order_no") @db.VarChar(50)
  userId             String         @map("user_id") @db.VarChar(32)
  treasureId         String         @map("treasure_id") @db.VarChar(32)
  originalAmount     Decimal        @map("original_amount") @db.Decimal(10, 2)
  discountAmount     Decimal        @map("discount_amount") @db.Decimal(10, 2)
  couponAmount       Decimal        @map("coupon_amount") @db.Decimal(10, 2)
  coinAmount         Decimal        @map("coin_amount") @db.Decimal(10, 2)
  finalAmount        Decimal        @map("final_amount") @db.Decimal(10, 2)
  buyQuantity        Int            @map("buy_quantity")
  unitPrice          Decimal        @map("unit_price") @db.Decimal(10, 2)
  /// // 1待支付 2已支付 3取消 4退款
  orderStatus        Int            @default(1) @map("order_status") @db.SmallInt
  payStatus          Int            @default(0) @map("pay_status") @db.SmallInt
  refundStatus       Int            @default(0) @map("refund_status") @db.SmallInt
  groupId            String?        @map("group_id") @db.VarChar(32)
  isGroupOwner       Int            @default(0) @map("is_group_owner") @db.SmallInt
  coinUsed           Decimal        @default(0) @map("coin_used") @db.Decimal(10, 2)
  paidAt             DateTime?      @map("paid_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  userCouponId       String?        @unique @map("user_coupon_id") @db.VarChar(32)
  hasBonus           Int            @default(0) @map("has_bonus") @db.SmallInt
  logisticsCo        String?        @map("logistics_co") @db.VarChar(50)
  shippingAddress    Json?          @map("shipping_address")
  /// 0-待发货 1-已发货 2-已签收
  shippingStatus     Int            @default(0) @map("shipping_status") @db.SmallInt
  trackingNo         String?        @map("tracking_no") @db.VarChar(50)
  /// 实际退款金额 (记录财务流水)
  refundAmount       Decimal?       @map("refund_amount") @db.Decimal(10, 2)
  /// 退款原因
  refundReason       String?        @map("refund_reason") @db.VarChar(255)
  /// 退款时间
  refundedAt         DateTime?      @map("refunded_at")
  refundAppliedBy    String?        @map("refund_applied_by")
  refundAuditedBy    String?        @map("refund_audited_by")
  refundRejectReason String?        @map("refund_reject_reason")
  paymentMethod      Int?           @map("payment_method") @db.SmallInt
  transactionId      String?        @map("transaction_id") @db.VarChar(100)
  /// 秒杀来源（退款时恢复 flashStock 必需）
  flashSaleProductId String?        @map("flash_sale_product_id") @db.VarChar(32)
  group              TreasureGroup? @relation(fields: [groupId], references: [groupId], onDelete: Cascade)
  treasure           Treasure       @relation(fields: [treasureId], references: [treasureId])
  userCoupon         UserCoupon?    @relation(fields: [userCouponId], references: [id])
  flashSaleProduct   FlashSaleProduct? @relation(fields: [flashSaleProductId], references: [id])
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_id_order")
  @@index([treasureId], map: "idx_treasure_id_order")
  @@index([orderStatus, payStatus], map: "idx_order_status")
  @@index([groupId], map: "idx_group_id_order")
  @@map("orders")
}

model SystemConfig {
  key   String @id @map("config_key") @db.VarChar(100)
  value String @map("config_value") @db.VarChar(255)

  @@map("system_configs")
}

/// 优惠券模板表 (印钞模板)
model Coupon {
  id             String       @id @default(cuid()) @map("coupon_id") @db.VarChar(32)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  /// 优惠券名称
  couponName     String       @map("coupon_name") @db.VarChar(200)
  /// 优惠券代码 (兑换码用)
  couponCode     String?      @unique @map("coupon_code") @db.VarChar(50)
  /// 类型: 1-满减券 2-折扣券 3-无门槛现金券
  couponType     Int          @map("coupon_type") @db.SmallInt
  /// 折扣类型: 1-固定金额(减10块) 2-百分比(打9折)
  discountType   Int          @default(1) @map("discount_type") @db.SmallInt
  /// 面额/折扣值 (如 10.00 或 0.90)
  discountValue  Decimal      @map("discount_value") @db.Decimal(10, 2)
  /// 最低消费门槛 (0代表无门槛)
  minPurchase    Decimal      @default(0) @map("min_purchase_amount") @db.Decimal(10, 2)
  /// 最高抵扣金额 (防止9折券买游艇亏死)
  maxDiscount    Decimal?     @map("max_discount_amount") @db.Decimal(10, 2)
  /// 发放类型: 1-系统发放 2-用户领取 3-兑换码 4-邀请奖励
  issueType      Int          @default(2) @map("issue_type") @db.SmallInt
  /// 发行总量 (-1代表不限量)
  totalQuantity  Int          @default(-1) @map("total_quantity")
  /// 已发放数量
  issuedQuantity Int          @default(0) @map("issued_quantity")
  /// 每人限领 (-1代表不限)
  perUserLimit   Int          @default(1) @map("per_user_limit")
  /// 有效期类型: 1-固定日期范围 2-领券后N天有效
  validType      Int          @default(1) @map("valid_type") @db.SmallInt
  validDays      Int?         @map("valid_days")
  validStartAt   DateTime?    @map("valid_start_time")
  validEndAt     DateTime?    @map("valid_end_time")
  /// 状态: 0-禁用/结束 1-进行中
  status         Int          @default(1) @map("status") @db.SmallInt
  description    String?      @map("description") @db.VarChar(500)
  ruleDesc       String?      @map("rule_desc")
  subTitle       String?      @map("sub_title") @db.VarChar(200)
  userCoupons    UserCoupon[]
  luckyDrawPrizes LuckyDrawPrize[]

  @@index([status])
  @@index([issueType])
  @@index([validStartAt, validEndAt])
  @@map("coupons")
}

/// 用户优惠券实例表 (用户手里的券)
model UserCoupon {
  id             String    @id @default(cuid()) @map("user_coupon_id") @db.VarChar(32)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  userId         String    @map("user_id") @db.VarChar(32)
  couponId       String    @map("coupon_id") @db.VarChar(32)
  /// 领取方式: 1-系统 2-主动 3-兑换 4-邀请
  receiveType    Int       @default(2) @map("receive_type") @db.SmallInt
  /// 使用状态: 0-未使用 1-已使用 2-已过期 3-作废
  status         Int       @default(0) @map("use_status") @db.SmallInt
  /// 实际抵扣金额
  discountAmount Decimal?  @map("discount_amount") @db.Decimal(10, 2)
  /// 使用时间
  usedAt         DateTime? @map("used_at")
  /// 有效期 (领取时计算固化下来，方便查询)
  validStartAt   DateTime  @map("valid_start_time")
  validEndAt     DateTime  @map("valid_end_time")
  order          Order?
  coupon         Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([validEndAt])
  @@map("user_coupons")
}

/// 21. 充值订单表
model RechargeOrder {
