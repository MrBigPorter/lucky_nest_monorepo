  bonusAmount       Decimal   @default(0.00) @map("bonus_amount") @db.Decimal(10, 2)
  actualAmount      Decimal   @map("actual_amount") @db.Decimal(10, 2)
  paymentMethod     Int       @map("payment_method") @db.SmallInt
  paymentChannel    String?   @map("payment_channel") @db.VarChar(50)
  paymentId         String?   @map("payment_id") @db.VarChar(32)
  rechargeStatus    Int       @default(1) @map("recharge_status") @db.SmallInt
  activityId        String?   @map("activity_id") @db.VarChar(32)
  firstRecharge     Int       @default(0) @map("first_recharge") @db.SmallInt
  thirdPartyOrderNo String?   @map("third_party_order_no") @db.VarChar(100)
  callbackData      Json?     @map("callback_data")
  paidAt            DateTime? @map("paid_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  channelCode       String?   @map("channel_code") @db.VarChar(50)
