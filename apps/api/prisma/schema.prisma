model WalletTransaction {
  id              String     @id @default(cuid()) @map("id") @db.VarChar(32)
  transactionNo   String     @unique @map("transaction_no") @db.VarChar(50)
  userId          String     @map("user_id") @db.VarChar(32)
  walletId        String     @map("wallet_id") @db.VarChar(32)
  transactionType Int        @map("transaction_type") @db.SmallInt
  balanceType     Int        @map("balance_type") @db.SmallInt
  amount          Decimal    @map("amount") @db.Decimal(10, 2)
  relatedId       String?    @map("related_id") @db.VarChar(64)
  relatedType     String?    @map("related_type") @db.VarChar(50)
  description     String?    @map("description")
  status          Int        @default(1) @map("status") @db.SmallInt
  createdAt       DateTime   @default(now()) @map("created_at")
  remark          String?    @map("remark") @db.VarChar(500)
  transactionId   String?    @map("transaction_id_ext") @db.VarChar(32)
  afterBalance    Decimal    @map("after_balance") @db.Decimal(10, 2)
  beforeBalance   Decimal    @map("before_balance") @db.Decimal(10, 2)
