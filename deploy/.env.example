# ==========================================
# 环境变量模板 — 复制为 .env.dev 或 .env.prod
# ==========================================
# cp deploy/.env.example deploy/.env.dev   ← 开发
# cp deploy/.env.example deploy/.env.prod  ← 生产
# ==========================================

NODE_ENV=development

# ------------------------------------------
# 1. 基础设施 (Docker Compose 插值)
# ------------------------------------------
POSTGRES_USER=dev
POSTGRES_PASSWORD=change_me
POSTGRES_DB=lucky_dev
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ------------------------------------------
# 2. API 数据库 / 缓存直连
# ------------------------------------------
DATABASE_URL=postgresql://dev:change_me@db:5432/lucky_dev?schema=public
REDIS_URL=redis://:change_me@redis:6379/0

# ------------------------------------------
# 3. 跨域 & 前端
# ------------------------------------------
CORS_ORIGIN=https://admin.joyminis.com
FRONTEND_URL=https://admin.joyminis.com

# ------------------------------------------
# 4. 缓存
# ------------------------------------------
CACHE_TTL=300
CACHE_PREFIX=lucky:

# ------------------------------------------
# 5. JWT
# ------------------------------------------
JWT_SECRET=change_me
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ------------------------------------------
# 6. OTP 验证码
# ------------------------------------------
OTP_DEV_CODE=999999
OTP_TTL_SECONDS=300
OTP_INTERVAL_SECONDS=60
OTP_LOGIN_WINDOW_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_PEPPER=change_me

# ------------------------------------------
# 7. Cloudflare R2 (文件上传)
# ------------------------------------------
CF_R2_ACCOUNT_ID=change_me
CF_R2_ACCESS_KEY_ID=change_me
CF_R2_SECRET_ACCESS_KEY=change_me
R2_BUCKET_PUBLIC=mini-shop
CF_R2_PUBLIC_DOMAIN=https://img.joyminis.com
R2_BUCKET_PRIVATE=mini-kyc-private

# ------------------------------------------
# 8. Xendit (支付网关)
# ------------------------------------------
XENDIT_ENVIRONMENT=development
XENDIT_SECRET_KEY=change_me
XENDIT_CALLBACK_TOKEN=change_me

# ------------------------------------------
# 9. AWS (KYC 活体检测)
# ------------------------------------------
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_REGION=us-east-1
KYC_LIVENESS_PASS_SCORE=85
KYC_FACE_MATCH_SCORE=90

# ------------------------------------------
# 10. Google API
# ------------------------------------------
GOOGLE_VISION_CREDENTIALS='change_me'
GOOGLE_MAPS_API_KEY=change_me

# ------------------------------------------
# 11. Firebase
# ------------------------------------------
FIREBASE_ADMIN_CREDENTIALS='change_me'

# ------------------------------------------
# 12. TURN Server
# ------------------------------------------
TURN_SECRET=change_me
TURN_URL=turn:your-server:3478

# ------------------------------------------
# 13. Email (Resend)  https://resend.com
# ------------------------------------------
# 不填或填 "disabled" 则静默跳过邮件发送（MVP 阶段可留空）
RESEND_API_KEY=disabled
# Resend 已验证域名才能自定义发件人，否则用 onboarding@resend.dev
EMAIL_FROM=JoyMini Admin <noreply@joyminis.com>

# ------------------------------------------
# 14. Google reCAPTCHA v3  https://www.google.com/recaptcha/admin
# ------------------------------------------
# 后端 Secret Key（server-side，保密）
RECAPTCHA_SECRET_KEY=disabled
# 前端 Site Key（client-side，可公开）→ 写入 compose.yml / compose.prod.yml
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

