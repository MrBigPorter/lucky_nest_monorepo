# ==========================================
# 开发环境统一配置 — deploy/.env.dev
# ==========================================
# ⚠️ 此文件包含敏感信息，严禁提交到 Git！
# ==========================================

NODE_ENV=development

# ------------------------------------------
# 1. 基础设施 (Docker Compose 插值)
# ------------------------------------------
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=lucky_dev
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=strongpass

# ------------------------------------------
# 2. API 数据库 / 缓存直连
# ------------------------------------------
DATABASE_URL=postgresql://dev:devpassword@db:5432/lucky_dev?schema=public
REDIS_URL=redis://:strongpass@redis:6379/0

# ------------------------------------------
# 3. 跨域 & 前端
# ------------------------------------------
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:64979,https://admin.joyminis.com,https://dev.joyminis.com
FRONTEND_URL=http://localhost:5173

# ------------------------------------------
# 4. 缓存
# ------------------------------------------
CACHE_TTL=300
CACHE_PREFIX=lucky:

# ------------------------------------------
# 5. JWT
# ------------------------------------------
JWT_SECRET=please_change_me_very_secret
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ------------------------------------------
# 6. OTP 验证码
# ------------------------------------------
OTP_DEV_CODE=999999
OTP_TTL_SECONDS=300
OTP_INTERVAL_SECONDS=60
OTP_LOGIN_WINDOW_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_PEPPER=optional_pepper_string

# ------------------------------------------
# 7. Cloudflare R2 (文件上传)
# ------------------------------------------
CF_R2_ACCOUNT_ID=24cb155b93f71f4c36912eab07089d07
CF_R2_ACCESS_KEY_ID=70d294a6750efb456476222db6517b38
CF_R2_SECRET_ACCESS_KEY=dc35a81bf0846afa7c9fe2aeb020bf2658a8f8f2fe1be690caf0d381993c63fb
R2_BUCKET_PUBLIC=mini-shop
CF_R2_PUBLIC_DOMAIN=https://img.joyminis.com
R2_BUCKET_PRIVATE=mini-kyc-private

