# ==========================================
# 1) 全局优化配置
# ==========================================

# Gzip 压缩
gzip on;
gzip_min_length 1k;
gzip_types application/json text/plain application/javascript text/css application/xml;

# 预检请求分流
map $request_method $is_options {
    default 0;
    OPTIONS 1;
}

# ==========================================
# 2) 主服务器 (HTTPS 443)
# ==========================================
server {
    listen 443 ssl;
    http2 on;

    server_name admin.joyminis.com dev-api.joyminis.com dev.joyminis.com;

    ssl_certificate     /etc/nginx/certs/admin.joyminis.com+4.pem;
    ssl_certificate_key /etc/nginx/certs/admin.joyminis.com+4-key.pem;

    proxy_ssl_server_name on;

    access_log /dev/stdout combined;
    error_log  /dev/stderr warn;

    #  1. 允许大文件上传 (500MB) - 必须配合下面的超时设置
    client_max_body_size 500M;

    # ========================================================
    #  A. 静态文件 & 特殊业务
    # ========================================================

    # 1. 中转分享页 (动态生成 OG 标签)
    location = /share.html {
        # 核心修改：在 backend:3000 后面加上完整的后端真实路由！
        # 还要把传递过去的参数也带上（$is_args$args 会把 ?pid=xxx 原封不动传过去）
        proxy_pass http://backend:3000/api/v1/share.html$is_args$args;

        # 透传真实的客户端信息
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 2. App Link / Universal Link 验证文件
    location ^~ /.well-known/ {
        root /var/www/html;
        default_type application/json;
        try_files $uri $uri/ =404;
    }

    # ========================================================
    #  B. 支付 Webhook
    # ========================================================
    location ~ ^/api/(v1/)?payment/webhook/xendit {
        proxy_pass http://backend:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ========================================================
    #  C. 媒体处理 (Cloudflare + Range 支持)
    # ========================================================

    # 1. Cloudflare Image Resizing 代理
    location ^~ /cdn-cgi/image/ {
        proxy_hide_header Access-Control-Allow-Origin;
        proxy_hide_header Access-Control-Allow-Methods;
        proxy_hide_header Access-Control-Allow-Headers;
        proxy_hide_header Access-Control-Expose-Headers;

        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET,HEAD,OPTIONS" always;
        add_header Access-Control-Allow-Headers "*" always;
        add_header Access-Control-Expose-Headers "Content-Length,Content-Range,Accept-Ranges" always;

        if ($is_options) { return 204; }

        proxy_buffering off;
        proxy_max_temp_file_size 0;

        proxy_pass https://img.joyminis.com;
        proxy_set_header Host img.joyminis.com;
        proxy_ssl_name img.joyminis.com;
    }

    # 2. 视频文件 (MP4/MOV) - 针对 Cloudflare 源站优化
    #  核心配置：SNI + Force Ranges
    location ~* ^/uploads/.*\.(mp4|mov|m4a)$ {
        # --- A. 跨域 (CORS) 设置 ---
        proxy_hide_header Access-Control-Allow-Origin;
        proxy_hide_header Access-Control-Allow-Methods;
        proxy_hide_header Access-Control-Allow-Headers;
        proxy_hide_header Access-Control-Expose-Headers;

        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET,HEAD,OPTIONS" always;
        add_header Access-Control-Allow-Headers "*" always;
        add_header Access-Control-Expose-Headers "Content-Length,Content-Range,Accept-Ranges" always;

        if ($is_options) { return 204; }

        # --- B. 缓冲与切片核心 (针对视频拖拽) ---
        proxy_buffering off;
        proxy_max_temp_file_size 0;

        #  核心 1: 强制开启 Nginx 切片支持
        proxy_force_ranges on;

        # --- C. 连接 Cloudflare 的关键配置 ---
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        #  核心 2: SNI 配置 (解决 CF 403 问题)
        proxy_ssl_server_name on;
        proxy_ssl_name img.joyminis.com;
        proxy_set_header Host img.joyminis.com;

        # 透传 Range 头
        proxy_set_header Range $http_range;
        proxy_pass_header Content-Range;
        proxy_pass_header Accept-Ranges;

        proxy_pass https://img.joyminis.com;
    }

    # 3. Uploads 通用兜底
    location ^~ /uploads/ {
        proxy_hide_header Access-Control-Allow-Origin;
        proxy_hide_header Access-Control-Allow-Methods;
        proxy_hide_header Access-Control-Allow-Headers;
        proxy_hide_header Access-Control-Expose-Headers;

        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET,HEAD,OPTIONS" always;
        add_header Access-Control-Allow-Headers "*" always;
        add_header Access-Control-Expose-Headers "Content-Length,Content-Range,Accept-Ranges" always;

        if ($is_options) { return 204; }

        proxy_buffering off;
        proxy_max_temp_file_size 0;

        proxy_pass https://img.joyminis.com;
        proxy_set_header Host img.joyminis.com;
        proxy_ssl_name img.joyminis.com;
    }

    # ========================================================
    #  D. 核心 API 与 权限控制
    # ========================================================

    # 1. 调账白名单接口
    location = /api/v1/admin/finance/adjust {
        include /etc/nginx/conf.d/whitelist.conf;
        deny all;

        proxy_pass http://backend:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 2. 文档入口
    location ~ ^/(docs|swagger-ui|api-json) {
        proxy_pass http://backend:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 3. 通用 API (含上传超时优化)
    location /api/ {
        # 这里必须加超时设置，否则上传大文件会被 Nginx 中断
        proxy_connect_timeout 600s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;

        if ($is_options) {
            add_header Access-Control-Allow-Origin '*' always;
            add_header Access-Control-Allow-Methods 'GET, POST, OPTIONS, PUT, DELETE, PATCH' always;
            add_header Access-Control-Allow-Headers '*' always;
            add_header Access-Control-Max-Age 1728000 always;
            add_header Content-Type 'text/plain; charset=utf-8';
            add_header Content-Length 0;
            return 204;
        }

        add_header Access-Control-Allow-Origin '*' always;
        add_header Access-Control-Allow-Headers '*' always;

        proxy_pass http://backend:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # ========================================================
    #  E. WebSocket / Socket.IO
    # ========================================================
    location ^~ /socket.io/ {
        proxy_pass http://backend:3000;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # ========================================================
    #  F. Admin 前端页面
    # ========================================================
    location / {
        proxy_pass http://mini-shop-admin:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}

# ==========================================
# 3) HTTP 跳转 (强制 HTTPS)
# ==========================================
server {
    listen 80;
    server_name admin.joyminis.com dev-api.joyminis.com dev.joyminis.com;
    return 301 https://$host$request_uri;
}